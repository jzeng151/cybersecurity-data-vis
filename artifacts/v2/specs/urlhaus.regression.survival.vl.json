        "family": "other",
        "offline_rate": 0.967,
        "n": 2396
      }
    ]
  },
  "mark": {
    "type": "line",
    "point": true,
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "agebin",
      "type": "ordinal",
      "sort": [
        "<1d",
        "1-3d",
        "3-7d",
        "7-14d",
        ">14d"
      ],
      "title": "URL age at snapshot (since dateadded)"
    },
    "y": {
      "field": "offline_rate",
      "type": "quantitative",
      "title": "offline rate",
      "axis": {
        "format": "%"
      },
      "scale": {
        "domain": [
          0,
          1
        ]
      }
    },
    "color": {
      "field": "family",
      "type": "nominal",
      "title": "campaign family",
      "scale": {
        "domain": [
          "A",
          "B",
          "other"
        ],
        "range": [
          "#3b82f6",
          "#e0a341",
          "#8a94a6"
        ]
      },
      "legend": {
        "labelExpr": "datum.label == 'A' ? 'A \u00b7 IoT botnet' : datum.label == 'B' ? 'B \u00b7 loader' : 'other'"
      }
    }
  }
}