        "n": 102
      },
      {
        "agebin": "1-3d",
        "family": "A",
        "offline_rate": 0.852,
        "n": 761
      },
      {
        "agebin": "1-3d",
        "family": "other",
        "offline_rate": 0.888,
        "n": 197
      },
      {
        "agebin": "3-7d",
        "family": "A",
        "offline_rate": 0.921,
        "n": 1548
      },
      {
        "agebin": "3-7d",
        "family": "B",
        "offline_rate": 0.005,
        "n": 5063
      },
      {
        "agebin": "3-7d",
        "family": "other",
        "offline_rate": 0.89,
        "n": 610
